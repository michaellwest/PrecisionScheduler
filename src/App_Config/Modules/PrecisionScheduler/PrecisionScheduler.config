<?xml version="1.0" encoding="utf-8" ?>
<configuration xmlns:patch="http://www.sitecore.net/xmlconfig/" xmlns:set="http://www.sitecore.net/xmlconfig/set/" xmlns:role="http://www.sitecore.net/xmlconfig/role/">
  <sitecore role:require="Standalone or ContentManagement">
    <pipelines>
      <owin.initialize>
        <processor type="PrecisionScheduler.Pipelines.Initialize.Scheduler, PrecisionScheduler">
          <StartupDelaySeconds>30</StartupDelaySeconds>
          <RefreshSchedule>*/2 * * * *</RefreshSchedule>
          <!--
            RefreshMisfireBehavior: how Hangfire handles missed ticks of the ManageJobs refresh
            job (e.g. if the server was down). This does NOT affect individual Sitecore schedule
            items — see StartupCatchUpEnabled and MissedJobLookbackDays for that.
            FireAll is intentionally unsupported: re-running a sync job N times adds no value.
            Options: FireOnce (Default), Ignore
          -->
          <RefreshMisfireBehavior>FireOnce</RefreshMisfireBehavior>
          <!--
            StartupCatchUpEnabled: whether to fire a single catch-up execution for jobs that
            missed their scheduled window during a server outage or restart.
            Set to false to disable all startup catch-up and let jobs resume their normal cadence.
            Default: true
          -->
          <StartupCatchUpEnabled>true</StartupCatchUpEnabled>
          <!--
            MissedJobLookbackDays: how far back (in days) to look for missed executions on startup.
            Applies only to infrequent jobs whose interval is one day or longer (e.g. daily, weekly).
            Sub-daily jobs (hourly, every N minutes) always use a one-interval window regardless
            of this value, since their next run is imminent.
            Default: 30
          -->
          <MissedJobLookbackDays>30</MissedJobLookbackDays>
        </processor>
      </owin.initialize>
    </pipelines>
    <scheduling>
      <!-- Replaced by the PrecisionScheduler -->
      <agent name="Master_Database_Agent">
        <patch:attribute name="interval" value="00:00:00" />
      </agent>
    </scheduling>
  </sitecore>
</configuration>